# ============================================================
#  GDelta Totem — deploy VPS (copie para .env e preencha)
#  NUNCA comite o .env real.
# ============================================================

# ── Supabase (os MESMOS valores do .env.local de teste; ou os de produção
#    quando for a hora — decisão do fundador) ───────────────────────────────
# (Necessárias TAMBÉM em runtime: o proxy/middleware do Next as lê a cada request.
#  O fluxo `cp .env.example .env` já cobre isso — não remova essas duas do .env.)
NEXT_PUBLIC_SUPABASE_URL=https://pvrnimckfgdmgjrjueap.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key do projeto>

# ── Domínio público do totem (registro DNS A aponta pro IP da VPS) ──────────
TOTEM_DOMAIN=totem.seudominio.com.br

# ── E-mail para o Let's Encrypt (avisos de certificado) ─────────────────────
CADDY_EMAIL=voce@exemplo.com

# ============================================================
#  SYNC com a planilha Google  (rota POST /api/sync/patio)
#  Opcional: só preencha quando for ligar o espelho do pátio.
# ============================================================
# Segredo que protege a rota (gere um aleatório forte; o cron manda no header)
SYNC_SECRET=<aleatorio-forte>
# Chave service role do Supabase (Project Settings → API). ⚠️ ignora RLS — só no servidor.
SUPABASE_SERVICE_ROLE_KEY=<service role key>
# Service Account do Google (a mesma do gdelta-local: gdelta-sheets@...iam.gserviceaccount.com)
GOOGLE_SA_EMAIL=gdelta-sheets@gdelta-bot-17730.iam.gserviceaccount.com
# Chave privada da SA, em UMA linha, com \n no lugar das quebras (entre aspas)
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Planilha e oficina do piloto (uma oficina por enquanto)
SYNC_SHEET_ID=1Rdfjh9MFRBc-9YH7CEEdfWXtaWdqFaTZ7lrESwdotL4
SYNC_OFICINA_ID=<uuid da oficina no Supabase>
# Aba de destino (dedicada; não toca no dashboard do dono)
SYNC_TAB=Totem · Pátio

# ============================================================
#  IA — leitura de orçamento em PDF (/admin/os → "Subir orçamento")
#  Opcional: só preencha pra ligar o pré-preenchimento por IA.
# ============================================================
# Chave da Anthropic (a mesma do projeto do bot). Cada leitura custa centavos.
ANTHROPIC_API_KEY=<sk-ant-...>
# Modelo (opcional). Default: claude-haiku-4-5 (barato e bom p/ extração).
# ORCAMENTO_MODEL=claude-haiku-4-5
